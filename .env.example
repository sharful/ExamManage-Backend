# Backend Environment Variables
# Copy this file to .env and fill in the values

# Database
# For Docker: host is "db" (the compose service name)
# For local dev: host is "localhost"
DATABASE_URL=postgresql+asyncpg://exammanage:exammanage@db:5432/exammanage

# JWT Auth
SECRET_KEY=change-me-to-a-random-256-bit-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000

# Encryption key for sensitive data (mobile numbers)
ENCRYPTION_KEY=change-me-to-a-random-32-byte-fernet-key
